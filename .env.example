# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LLM（Provider Switch）
# 真实 key 请写到 .env.local（gitignored），不要进 git
LLM_PROVIDER=openai
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.MiniMax.chat/v1
# LLM_MODEL=MiniMax-M3
# LLM_TEMPERATURE=0.7
# LLM_TIMEOUT_MS=30000
# 主备（可选，启用 LLM 主备路由）
# LLM_BASE_URL_BACKUP=https://backup-provider.com/v1
# LLM_API_KEY_BACKUP=sk-...

# Crisis Hotline（公开资源）
NEXT_PUBLIC_CRISIS_HOTLINE_BJ=010-82951332
NEXT_PUBLIC_CRISIS_TEXT_NAME=北京心理危机研究与干预中心

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
